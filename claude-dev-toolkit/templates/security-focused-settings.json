{
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*.md)",
      "Edit(*.txt)",
      "Edit(*.json)",
      "Edit(*.yml)",
      "Edit(*.yaml)",
      "Bash(git *)",
      "Bash(npm run *)",
      "Bash(python -m *)",
      "Bash(node *)",
      "Glob(*)",
      "Grep(*)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Bash(*production*)",
      "Bash(*admin*)",
      "Edit(/etc/*)",
      "Edit(/root/*)",
      "Edit(~/.ssh/*)",
      "Read(/etc/passwd)",
      "Read(/etc/shadow)",
      "Read(~/.aws/*)",
      "Read(~/.ssh/id_*)"
    ]
  },
  "hooks": {
    "PreToolUse": [],
    "PostToolUse": []
  },
  "env": {
    "DISABLE_TELEMETRY": "1",
    "ANTHROPIC_LOG": "error"
  },
  "includeCoAuthoredBy": false,
  "cleanupPeriodDays": 7,
  "enableAllProjectMcpServers": false
}
