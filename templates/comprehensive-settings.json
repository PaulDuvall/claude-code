{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "NotebookEdit(*)"
    ],
    "ask": [
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Edit(/etc/*)",
      "Read(~/.ssh/*)"
    ],
    "deny": [
      "Bash(*production*)",
      "Bash(*admin*)",
      "Read(/etc/shadow)",
      "Edit(/etc/passwd)"
    ]
  },
  "hooks": {
    "PreToolUse": [],
    "PostToolUse": []
  },
  "env": {
    "DISABLE_TELEMETRY": "1",
    "ANTHROPIC_LOG": "info"
  },
  "includeCoAuthoredBy": true,
  "cleanupPeriodDays": 30,
  "model": "claude-sonnet-4-6",
  "enableAllProjectMcpServers": false
}
